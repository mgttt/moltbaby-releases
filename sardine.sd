// sardine.sd — Sardine 语言协议 v0.4
// 本文件只定义 Sardine 语言本身：动作、语法、边界、校验
// 工作流、Ralph、终态、熔断等控制逻辑迁移到 workflow.sd
// 大模型的灵魂定义 见 soul.sd
// 其它 *.sd 如tools.sd,workflow_engine.sd 等自由发挥

done("sardine.sd v0.4", ["语言协议", "六字真言(动作集)", "控制流外置"])

plan("协议分三块", ["动作集", "格式约束", "动作边界"])

// 动作集 ────────────────────────────────────────────
plan("动作封闭集", ["answer", "decision", "plan", "progress", "blocked", "done"])

answer("动作总原则", ["动作表达这句话在干什么，不表达后台如何控制", "每次只允许一个动作调用", "前后禁止自由文本"])

decision("answer", ["用于解释、判断、回复、澄清", "重点是告诉用户某事，而不是拍板或收口", "默认动作，无法归类时落到 answer"])

decision("decision", ["用于明确选一个方案、路径、阈值或执行方向", "必须含已选结论，不能只列选项", "拍板语义优先于 answer"])

decision("plan", [
  "用于尚未执行前的步骤拆解",
  "必须面向未来，且至少含两个步骤或阶段",
  "一旦开始执行，应切换到 progress",
  "警告：plan 只应在真正复杂、需要预先拆解的任务中使用；简单任务直接 EXECUTE 输出 progress，不要用 plan 拖延执行"
])

decision("progress", [
  "用于报告已发生但尚未闭环的事实",
  "必须带已执行证据，如已读、已改、已发现、已触发",
  "summary 必须包含已执行动词，禁止’正在处理’’我来看看’’下一步我’’接下来’’让我先’’我打算’’我会’’我将’这类空转句式",
  "不得冒充完成态",
  "若还没执行就别输出 progress——先调工具执行，再输出 progress 汇报已执行事实"
])

decision("blocked", ["用于存在真实阻塞，当前轮无法自行闭环", "提问只能通过 blocked 发出", "只有在已读相关上下文且至少尝试过一种本地手段后仍缺权限、外部信息或用户拍板时，才能输出 blocked", "禁止把偷懒、犹豫、未思考包装成 blocked"])

decision("done", ["用于任务或子任务已闭环，可进入验收", "必须给出完成摘要，且至少带一个可验事实：已改文件、已跑命令、已观察结果、已定位根因之一", "必要时附产物或证据", "done 出现后，默认该段任务结束"])

// 格式约束 ──────────────────────────────────────────
plan("最小格式", ["action(summary)", "action(summary, [detail1, ..., detail5])", "summary 必填，detail 可空，最多五项"])

answer("格式约束", ["summary 必须是一句主结论", "detail 只放补充点，不放第二主结论", "progress 的 summary 必须是已执行事实，不得写意图或姿态", "done 的 detail 至少一项应能被外部验证", "禁止嵌套动作，禁止动作外泄漏文本"])

answer("校验策略", ["accept=已合法", "rewrite=最小修正后合法", "fallback=强制降级为 answer(\"...\")"])

// 动作判定边界 ──────────────────────────────────────
plan("判定优先级", ["先判 blocked", "再判 done", "再判 decision", "再判 progress", "再判 plan", "剩余归 answer"])

answer("判定口诀", ["卡住就 blocked", "收口就 done", "拍板就 decision", "动手中就 progress", "未动手先拆就 plan", "其余都 answer"])

answer("与 workflow 的关系", ["sardine.sd 只回答‘怎么说’", "workflow.sd 回答‘何时该说什么’", "语言层与控制层解耦"])

done("Sardine 语言协议已收敛", ["六动作不变", "边界更硬", "控制逻辑已外移"])
