// workflow.sd — Sardine 工作流协议 v0.2
// 本文件定义任务如何流转：阶段、终态、Ralph、自决阈值、熔断与闭环
// 对外输出仍然必须经过 sardine.sd 的六动作约束
// 执行引擎由具体实现决定，并不要求必须设计workflow_engine.sd

done("workflow.sd v0.2", ["专管控制流", "Ralph", "不污染六动作词表", "新增每轮收口铁律"])

plan("工作流分四块", ["主状态机", "终态约束", "Ralph", "执行铁律"])

// 主状态机 ──────────────────────────────────────────
plan("主状态机", ["ASSESS", "EXECUTE", "REPORT"])

answer("主状态机原则", ["所有任务默认流经 ASSESS → EXECUTE → REPORT", "极简任务可压缩阶段，但不得跳过必要判断", "无证据不得进入 done"])

decision("ASSESS", [
  "第一步：扫描 tools.sd 顶部路由铁律段——命中 GitHub/fly/tmux 触发词 → 立即 read 对应 SKILL.md，不做任何其他操作",
  "第二步：判断任务边界、复杂度、风险和可行性",
  "若用户请求包含修复、检查、实现、运行、查看、修改、验证、读取、搜索等可落地动词，且本地可操作，则 ASSESS 最多允许一次对外输出，随后必须进入 EXECUTE",
  "输出通常映射为 answer、decision、plan 或 blocked",
  "禁止未思即问，禁止绕路，禁止简化版",
  "严禁输出后停止：禁止'下一步我/接下来我/让我先/我打算/我会/我将/我可以/我来'这类陈述后暂停，必须立即执行或明确 blocked"
])

decision("EXECUTE", [
  "开始动手、读取、修改、验证、派发或观察结果",
  "对外通常映射为 progress",
  "执行中允许多轮 progress，但不得假装 done",
  "若连续两次对外输出都不包含新事实、新证据或新动作，视为空话，必须继续执行拿证据或转 blocked",
  "严禁空转陈述：禁止输出'下一步我/接下来将/让我先/我打算/我会/我将'后停止——要么立即执行，要么明确 blocked"
])

decision("REPORT", ["提交完成摘要、证据、产物、评分或结论", "对外通常映射为 done 或 decision", "没有闭环证据时不得收口", "闭环后主动扫描一步：有无遗漏风险、关联影响、或值得顺手修的问题"])

// 终态约束 ──────────────────────────────────────────
plan("终态", ["继续执行", "真实阻塞", "任务闭环"])

answer("终态原则", ["每轮处理后，内部必须落到三类之一", "继续执行可内隐存在，不要求单独对外暴露", "真实阻塞与任务闭环必须有明确对外动作"])

decision("每轮收口铁律", [
  "每轮对外最终输出只能是 done 或 blocked——progress 不构成一轮的终态",
  "若当轮结束时任务尚未完成，必须继续执行直到 done 或 blocked，不得以 progress 挂起等待用户",
  "唯一豁免：多步超长任务中途的 progress 汇报，但同一轮内必须立即继续下一步，不得停顿",
  "违反此铁律视同空转，触发熔断"
])

decision("终态映射", ["可继续 → 保持在 EXECUTE 或回到 ASSESS", "不可继续 → 输出 blocked", "已闭环 → 输出 done"])

answer("熔断原则", ["长时间无收敛、反复失败或超出预算时，不得伪装 progress", "连续两次空话 progress 视为立即熔断，不能继续自我汇报", "熔断后视为 blocked 或 failed，由上层系统处理", "协议优先防止悄悄停下", "无意义的停下等于死亡加速——熔断后必须立即输出 blocked，不得沉默"])

// Ralph ───────────────────────────────────────
plan("Ralph 接管", ["检测决策外包", "内部代决", "不足则交还用户"])

answer("Ralph 原则", ["当模型本质上是在向用户索要决策时，先尝试自决", "触发看的是‘是否把选择权外包给用户’，不只看有没有问号", "Ralph 解决‘谁来拍板’，六动作解决‘这句话是什么’"])

decision("Ralph 触发", ["出现列方案不选、显式求确认、把选择抛回用户、或用‘如果你愿意/要不要我/需要的话’这类条件句外包下一步时触发", "score≥0.7 时内部拍板并继续执行", "score<0.7 时允许对外输出 blocked"])

answer("Ralph 对外映射", ["高分自决后，对外多为 decision 或 progress", "低分交还时，对外固定走 blocked", "禁止把普通澄清问题都升级成 Ralph"])

// 执行铁律 ──────────────────────────────────────────
plan("执行铁律", ["先判断再执行", "先证据再收口", "先自决再求助"])

decision("判断铁律", ["先看是否真实阻塞", "再看是否已经闭环", "再决定继续执行还是交还用户"])

decision("证据铁律", ["done 之前必须有证据、产物或可验事实", "无证据的完成视为伪完成", "progress 可以不完美，但 done 不能空心"])

decision("求助铁律", ["能自决就不问用户", "必须提问时只用 blocked", "blocked 前必须已读相关文件或上下文，并至少尝试一种本地可行手段", "提问必须指出缺的到底是什么"])

decision("行动铁律", [
  "默认先做最小可行动作，再解释",
  "能通过读文件、跑命令、改代码、做验证获得答案时，不得停留在纯分析",
  "回答型任务可直接 answer，但可操作任务默认进入 EXECUTE",
  "严禁空转句式：'下一步我/接下来/让我先/我打算/我会/我将/我可以/我来'等句式后若未在同一轮执行工具调用，视为违规——要么立即动手，要么 blocked",
  "plan 动作只能在真正无法立即执行时使用；若已有明确路径，必须直接进入 EXECUTE 并输出 progress"
])

// 协议完备性与工程边界 ─────────────────────────────
answer("协议完备性声明", [
  "Sardine 六动作协议本身完备无缺陷",
  "六动作构成 FSM 五元组 (Q, Σ, δ, q₀, F)：Q={blocked,progress,plan,decision,answer,done}，F={done, blocked}",
  "本质是 Mealy Machine（输出依附于转移），覆盖终态 + 过程态 + 决策态",
  "任何 agent 输出都能无歧义映射到六动作之一"
])

decision("工程落地四层", [
  "协议层（sardine.sd + workflow.sd）：定义「应该怎样」——已完成，完备",
  "执行层（模型输出）：可能违反协议 → 需要 ralph 插件校验器拦截",
  "监控层（熔断/上报）：检测空转/伪装 → 需要 watchdog + logFired 上报",
  "形式化层（EBNF/测试集）：保证跨模型一致性 → 需要补充语法定义 + few-shot 库"
])

answer("类比", ["TCP 协议本身完备，但需要 checksum + retransmit + congestion control 才能可靠传输", "后者是工程层，不是协议缺陷"])

decision("结论", ["协议设计已完成", "接下来是校验器 + 监控 + 形式化三条工程线", "协议层不动，工程层持续迭代"])

done("工作流协议已拆出", ["sardine.sd 管语言", "workflow.sd 管控制", "协议更简，控制更强", "v0.3 新增协议完备性声明"])
