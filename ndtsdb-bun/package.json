{
  "name": "ndtsdb",
  "version": "1.0.0.1",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts"
    }
  },
  "files": ["dist/", "src/", "native/"],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "description": "TypeScript/Bun FFI wrapper for ndtsdb-lib (N-dimensional time-series database)",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --sourcemap=linked && bun x tsc --emitDeclarationOnly",
    "build:clean": "rm -rf dist && bun run build",
    "test": "bun test tests/ndtsdb.test.ts",
    "test:all": "bun test tests/",
    "test:smoke": "bun tests/smoke-test.ts",
    "test:suite": "bun tests/test-suite.ts",
    "test:qjs-rpc": "./scripts/build-qjs-rpc.sh && bun test tests/ndtsdb-rpc.test.ts",
    "benchmark": "bun tests/benchmark.ts",
    "benchmark:3000": "bun tests/benchmark-3000.ts --full",
    "example": "bun tests/example.ts",
    "typecheck": "bun x tsc --noEmit"
  },
  "type": "module"
}
